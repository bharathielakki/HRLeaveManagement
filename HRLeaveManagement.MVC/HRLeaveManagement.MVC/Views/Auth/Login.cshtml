@model LoginModel

<style>
    body {
        font-family: Arial, sans-serif;
        background-color: #f4f6f9;
    }

    .login-container {
        width: 350px;
        margin: 120px auto;
        padding: 30px;
        background: white;
        border-radius: 10px;
        box-shadow: 0px 4px 10px rgba(0,0,0,0.1);
        text-align: center;
    }

        .login-container h2 {
            margin-bottom: 20px;
        }

    .form-group {
        margin-bottom: 15px;
        text-align: left;
    }

    label {
        font-weight: 600;
        display: block;
        margin-bottom: 5px;
    }

    input {
        width: 100%;
        padding: 8px;
        border: 1px solid #ccc;
        border-radius: 5px;
    }

    button {
        width: 100%;
        padding: 10px;
        background-color: #007bff;
        border: none;
        color: white;
        font-weight: bold;
        border-radius: 5px;
        cursor: pointer;
    }

        button:hover {
            background-color: #0056b3;
        }

    .error {
        color: red;
        margin-top: 10px;
    }
</style>

<div class="login-container">

    <h2>Login</h2>

    <form method="post">

        <div class="form-group">
            <label>Username</label>
            <input asp-for="Username" />
        </div>

        <div class="form-group">
            <label>Password</label>
            <input asp-for="Password" type="password" />
        </div>

        <button type="submit">Login</button>

        @if (ViewBag.Error != null)
        {
            <p class="error">@ViewBag.Error</p>
        }

    </form>

</div>
